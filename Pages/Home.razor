@page "/"

<PageTitle>Orthodox Prayer Today</PageTitle>

<div class="notification-bar">
    <span>
        This is a work in progress. Please consult your local Orthodox Priest for your prayer rule!
    </span>
</div>
<div style="padding: 20px;"></div>


<div class="top-controls">
    <div>
        <input type="date" @bind-value="@(Date)">
    </div>
    <div>
        <LanguageSelector />
    </div>
    @if (HolidayCalculator.IsLent(DateOnly.FromDateTime(Date)))
    {
        var paschaDate = HolidayCalculator.GetPascha(Date.Year);
        <Note>It is Pascha Season (Pascha is in @(paschaDate.ToDateOnlyAtTime0().Subtract(Date.Date).TotalDays) days on @(paschaDate.ToString("MMMM dd")))</Note>
    }
    else if (HolidayCalculator.IsNativityFast(DateOnly.FromDateTime(Date)))
    {
        <Note>It is Nativity Season (@(new DateOnly(Date.Year, 12, 25).ToShortDateString()))</Note>
    }
</div>

<div class="main-prayer-buttons">
    <div>
        <ButtonLink OnClick="() => SetMainPrayerKind(MainPrayerChoiceKind.MorningPrayer)">
            Morning
        </ButtonLink>
    </div>
    <div>
        <ButtonLink OnClick="() => SetMainPrayerKind(MainPrayerChoiceKind.EveningPrayer)">
            Evening
        </ButtonLink>
    </div>
    <div>
        <ButtonLink OnClick="() => SetMainPrayerKind(MainPrayerChoiceKind.Meal)">
            Meal
        </ButtonLink>
    </div>

    @if (MainUtil.IsDebug)
    {
        <div>
            <ButtonLink OnClick="() => SetMainPrayerKind(MainPrayerChoiceKind.Other)">
                Other
            </ButtonLink>
        </div>
    }

    @if (!choiceKindsWithNoRandom.Contains(MainPrayerChoice))
    {
        <div>
            <ButtonLink OnClick="() => NilsEventService.NotifyRandomClicked()"
                        BackgroundColor="@(StaticColors.LightBeige)">
                <DiceIcon />
            </ButtonLink>
        </div>
    }
</div>

<LoadingContainer IsLoading="IsLoading" ContainerStyle="">
    <div class="main-prayer-container">
        @switch (MainPrayerChoice)
        {
            case MainPrayerChoiceKind.MorningPrayer:
                <MorningPrayer Date="Date" />
                break;
            case MainPrayerChoiceKind.EveningPrayer:
                <EveningPrayer Date="Date" />
                break;
            case MainPrayerChoiceKind.Meal:
                <MealPrayer />
                break;
            case MainPrayerChoiceKind.Other:
                <OtherPrayers Date="Date" />
                break;
            default:
                <div>Select a prayer.</div>
                break;
        }
    </div>
</LoadingContainer>

