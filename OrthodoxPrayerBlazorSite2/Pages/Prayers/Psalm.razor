@page "/prayers/psalm"
@using Microsoft.AspNetCore.Components
@implements IDisposable

@switch (selectedPsalm)
{
    case 4:
        <Psalm4 HeadingKind="HeadingKind" />
        break;
    case 5:
        <Psalm5 HeadingKind="HeadingKind" />
        break;
    case 50:
        <Psalm50 HeadingKind="HeadingKind" />
        break;
    case 62:
        <Psalm62 HeadingKind="HeadingKind" />
        break;
    case 90:
        <Psalm90 HeadingKind="HeadingKind" />
        break;
    case 102:
        <Psalm102 HeadingKind="HeadingKind" />
        break;
    case 133:
        <Psalm133 HeadingKind="HeadingKind" />
        break;
    case 140:
        <Psalm140 HeadingKind="HeadingKind" />
        break;
    case 142:
        <Psalm142 HeadingKind="HeadingKind" />
        break;
    case 120: // randomly selected as default
    default:
        <Psalm120 HeadingKind="HeadingKind" />
        break;
}

@code {
    [Parameter, EditorRequired]
    public HeadingKindEnum HeadingKind { get; set; }

    [Parameter, EditorRequired]
    public bool IsBrief { get; set; } = false;

    [Parameter, EditorRequired]
    public PsalmTimeOfDayKindEnum PsalmTimeOfDayKind { get; set; } = PsalmTimeOfDayKindEnum.Morning;
}
