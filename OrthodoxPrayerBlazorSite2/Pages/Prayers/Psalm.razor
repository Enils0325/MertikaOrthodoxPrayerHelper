@page "/prayers/psalm"
@using Microsoft.AspNetCore.Components
@implements IDisposable

@if (PsalmTimeOfDayKind == PsalmTimeOfDayKindEnum.Morning)
{
    if (IsBrief)
    {
        <RandomizablePrayer Items="RandomizableBriefMorningPsalms" />
    }
    else
    {
        <RandomizablePrayer Items="RandomizableMorningPsalms" />
    }
}
else
{
    if (IsBrief)
    {
        <RandomizablePrayer Items="RandomizableBriefEveningPsalms" />
    }
    else
    {
        <RandomizablePrayer Items="RandomizableEveningPsalms" />
    }
}

@code {
    [Parameter, EditorRequired]
    public HeadingKindEnum HeadingKind { get; set; }

    [Parameter, EditorRequired]
    public bool IsBrief { get; set; } = false;

    [Parameter, EditorRequired]
    public PsalmTimeOfDayKindEnum PsalmTimeOfDayKind { get; set; } = PsalmTimeOfDayKindEnum.Morning;

    private ImmutableList<RenderFragment> RandomizableBriefMorningPsalms = [];
    private ImmutableList<RenderFragment> RandomizableMorningPsalms = [];

    private ImmutableList<RenderFragment> RandomizableBriefEveningPsalms = [];
    private ImmutableList<RenderFragment> RandomizableEveningPsalms = [];

    protected override void OnInitialized()
    {
        RandomizableMorningPsalms = [
            @<Psalm5 HeadingKind="HeadingKind" />,
            @<Psalm50 HeadingKind="HeadingKind" />,
            @<Psalm62 HeadingKind="HeadingKind" />,
            @<Psalm102 HeadingKind="HeadingKind" />,
            @<Psalm142 HeadingKind="HeadingKind" />,
        ];
        
        RandomizableBriefMorningPsalms = [
            @<Psalm50 HeadingKind="HeadingKind" />,
            @<Psalm62 HeadingKind="HeadingKind" />,
        ];
        
        RandomizableEveningPsalms = [
            @<Psalm4 HeadingKind="HeadingKind" />,
            @<Psalm90 HeadingKind="HeadingKind" />,
            @<Psalm140 HeadingKind="HeadingKind" />,
            @<Psalm120 HeadingKind="HeadingKind" />,
            @<Psalm133 HeadingKind="HeadingKind" />,
        ];
        
        RandomizableBriefEveningPsalms = [
            @<Psalm4 HeadingKind="HeadingKind" />,
            @<Psalm120 HeadingKind="HeadingKind" />,
            @<Psalm133 HeadingKind="HeadingKind" />,
        ];

        base.OnInitialized();
    }
}
