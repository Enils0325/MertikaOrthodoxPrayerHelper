
<Heading HeadingKind="HeadingKindEnum.SubHeading">
    Pregnancy Prayers
</Heading>

<InputRadioGroup @bind-Value="ForWhomPregnancyKind">
    <div class="radio-group-container">
        <div>
            <InputRadio Value="ForWhomPregnancyKindEnum.Me" id="radioOptionMe" />
            <label for="radioOptionMe">Me</label>
        </div>
        <div>
            <InputRadio Value="ForWhomPregnancyKindEnum.AnotherWoman" id="radioOptionANotherWoman" />
            <label for="radioOptionANotherWoman">Another Woman</label>
        </div>
    </div>
</InputRadioGroup>

<InputRadioGroup @bind-Value="GenderKind">
    <div class="radio-group-container">
        <div>
            <InputRadio Value="GenderKindEnum.Male" id="radioOptionMale" />
            <label for="radioOptionMale">Baby is a boy</label>
        </div>
        <div>
            <InputRadio Value="GenderKindEnum.Female" id="radioOptionFemale" />
            <label for="radioOptionFemale">Baby is a girl</label>
        </div>
        <div>
            <InputRadio Value="GenderKindEnum.Unknown" id="radioOptionUnknown" />
            <label for="radioOptionUnknown">Unknown</label>
        </div>
    </div>
</InputRadioGroup>

@if (ForWhomPregnancyKind == ForWhomPregnancyKindEnum.AnotherWoman)
{
    <InputText @bind-Value="InputtedWomanName" placeholder="Enter woman's name" />
}

@if (ForWhomPregnancyKind == ForWhomPregnancyKindEnum.Me)
{
    switch (LanguageKind)
    {
        case LanguageKindEnum.EnglishOlder:
        {
            <PrayerLine>
                O Sovereign Lord Jesus Christ our God, the Source of life and immortality, I thank Thee, for in my marriage Thou has blest me to be a recipient of Thy blessing and gift; for Thou, O Master, didst say: Be fruitful and multiply and replenish the earth.
            </PrayerLine>
            <PrayerLine>
                I thank Thee and pray: Bless this fruit of my body that was given to me by Thee; favor @(GenderKind.Him("this child")) and animate @(GenderKind.Him()) by Thy Holy Spirit, and let @(GenderKind.Him()) grow a healthy and pure body, with well-formed limbs.
            </PrayerLine>
            <PrayerLine>
                Sanctify @(GenderKind.His()) body, mind, heart, and vitals, and grant this infant that is to be born an intelligent soul; establish @(GenderKind.Him()) in the fear of Thee.
            </PrayerLine>
            <PrayerLine>
                A faithful angel, a guardian of soul and body, do thou vouchsafe @(GenderKind.Him()). Protect, keep, strengthen, and shelter the child in my womb until the hour of birth. But conceal @(GenderKind.Him()) not in @(GenderKind.His()) mother's womb; Thou gavest @(GenderKind.Him("this child")) life and health.
            </PrayerLine>
            <PrayerLine>
                O Lord Jesus Christ, into Thine almighty and paternal hands do I entrust my child. Place @(GenderKind.Him()) upon the right hand of Thy grace, and through Thy Holy Spirit sanctify @(GenderKind.Him("this child")) and renew @(GenderKind.Him()) unto life everlasting, that @(GenderKind.He()) may be a comminucant of Thy Heavenly Kingdom. Amen.
            </PrayerLine>
        }
        break;
        case LanguageKindEnum.EnglishModern:
        case LanguageKindEnum.EnglishMixed:
        default:
        {
            <PrayerLine>
                O Sovereign Lord Jesus Christ our God, the Source of life and immortality, I thank You, for in my marriage You have given me Your blessing and gift; for You, O Master, did say: Be fruitful and multiply and replenish the earth.
            </PrayerLine>
            <PrayerLine>
                I thank You and pray: Bless the fruit of my body that was given to me by You; favor @(GenderKind.Him("this child")) and animate @(GenderKind.Him()) by Your Holy Spirit, and let @(GenderKind.Him()) grow a healthy and pure body, with well-formed limbs.
            </PrayerLine>
            <PrayerLine>
                Sanctify @(GenderKind.His()) body, mind, heart, and vitals, and grant this infant that is to be born an intelligent soul; establish @(GenderKind.Him()) in the fear of Thee.
            </PrayerLine>
            <PrayerLine>
                A faithful angel, guardian of soul and body, watch over @(GenderKind.Him()). Protect, keep, strengthen, and shelter the child in my womb until the hour of @(GenderKind.His()) birth. But shelter @(GenderKind.Him()) not in @(GenderKind.His()) mother's womb; You have given @(GenderKind.Him("this child")) life and health.
            </PrayerLine>
            <PrayerLine>
                O Lord Jesus Christ, into Your almighty and paternal hands do I entrust my child. Place @(GenderKind.Him()) upon the right hand of Your grace, and through Your Holy Spirit sanctify @(GenderKind.Him("this child")) and renew @(GenderKind.Him()) unto life everlasting, that @(GenderKind.He()) may be a comminucant of Your Heavenly Kingdom. Amen.
            </PrayerLine>
        }
            break;
    }
}
else
{
    switch (LanguageKind)
    {
        case LanguageKindEnum.EnglishOlder:
        {
            <PrayerLine>
                O Sovereign Lord Jesus Christ our God, the Source of life and immortality, bless @(WomanName) and the fruit of her body that was given by Thee, favor them and animate @(GenderKind.Him("this child")) by Thy Holy Spirit, and let it grow a healthy and pure body, with well-formed limbs.
            </PrayerLine>
            <PrayerLine>
                Sanctify @(GenderKind.His()) body, mind, heart, and vitals, and grant this infant that is to be born an intelligent soul; establish @(GenderKind.Him()) in the fear of Thee.
            </PrayerLine>
            <PrayerLine>
                A faithful angel, a guardian of soul and body, do thou vouchsafe @(GenderKind.Him()). Protect, keep, strengthen, and shelter the child until the hour of birth. 
            </PrayerLine>
            <PrayerLine>
                O Lord Jesus Christ, place this infant upon the right hand of Thy grace, and through Thy Holy Spirit sanctify @(GenderKind.Him()) and renew @(GenderKind.Him()) unto life everlasting, that @(GenderKind.He()) may be a comminucant of Thy Heavenly Kingdom. Amen.
            </PrayerLine>
        }
        break;
        case LanguageKindEnum.EnglishModern:
        case LanguageKindEnum.EnglishMixed:
        default:
        {
            <PrayerLine>
                O Sovereign Lord Jesus Christ our God, the Source of life and immortality, bless @(WomanName) and the fruit of her body that was given by You, favor them and animate @(GenderKind.Him("this child")) by Thy Holy Spirit, and let it grow a healthy and pure body, with well-formed limbs.
            </PrayerLine>
            <PrayerLine>
                Sanctify @(GenderKind.His()) body, mind, heart, and vitals, and grant this infant that is to be born an intelligent soul; establish @(GenderKind.Him()) in the fear of Thee.
            </PrayerLine>
            <PrayerLine>
                A faithful angel, guardian of soul and body, watch over @(GenderKind.Him()). Protect, keep, strengthen, and shelter the child until the hour of birth.
            </PrayerLine>
            <PrayerLine>
                O Lord Jesus Christ, place @(GenderKind.Him("this child")) upon the right hand of Your grace, and through Your Holy Spirit sanctify @(GenderKind.Him()) and renew @(GenderKind.Him()) unto life everlasting, that @(GenderKind.He()) may be a comminucant of Your Heavenly Kingdom. Amen.
            </PrayerLine>
        }
        break;
    }
}


@code {
    [Parameter]
    public HeadingKindEnum HeadingKind { get; set; } = HeadingKindEnum.None;

    [CascadingParameter]
    public LanguageKindEnum LanguageKind { get; set; } = LanguageKindEnum.EnglishModern;

    private ForWhomPregnancyKindEnum ForWhomPregnancyKind { get; set; } = ForWhomPregnancyKindEnum.Me;
    private GenderKindEnum GenderKind { get; set; } = GenderKindEnum.Unknown;

    private string InputtedWomanName { get; set; } = string.Empty;
    private string WomanName => string.IsNullOrWhiteSpace(InputtedWomanName) ? "(name)" : InputtedWomanName.Trim();



    private enum ForWhomPregnancyKindEnum { AnotherWoman, Me, }
}
